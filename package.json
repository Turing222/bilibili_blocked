{
  "name": "bilibili-blocked",
  "private": true,
  "license": "CC-BY-NC-SA-4.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/build-userjs.mjs",
    "build:require": "node scripts/build-userjs.mjs --require",
    "tm:dev": "node scripts/tampermonkey-dev.mjs",
    "tm:dev:build": "node scripts/tampermonkey-dev.mjs --build-only",
    "test": "node --test tests/*.test.js",
    "check": "node scripts/build-userjs.mjs && node --check dist/bilibili_blocked_videos_by_tags.user.js && npm run test",
    "perf:boundary": "node scripts/perf-boundary.mjs",
    "lint": "eslint src tests scripts/lib",
    "pw:chrome": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File tools/bilibili-browser/start-chrome.ps1",
    "pw:smoke": "node scripts/playwright-smoke.mjs",
    "pw:comment-timing": "node scripts/comment-timing-smoke.mjs",
    "pw:video-card-timing": "node scripts/video-card-timing-smoke.mjs",
    "pw:oracle-compare": "node tools/bilibili-browser/oracle-mcp-compare.mjs",
    "pw:mcp-probe": "node tools/bilibili-browser/mcp-probe-collect.mjs",
    "pw:normalize-results": "node tools/bilibili-browser/normalize-results.mjs",
    "pw:baseline": "node scripts/capture-smoke-baselines.mjs",
    "pw:inspect": "node tools/bilibili-browser/inspect-comments.mjs",
    "ci:deterministic-smoke": "npm run build && node scripts/ci-deterministic-smoke.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@playwright/test": "1.61.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0"
  }
}
